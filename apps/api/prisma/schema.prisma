generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String            @id
  name             String
  slug             String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users                User[]
  connections          IntegrationConnection[]
  teams                Team[]
  projects             Project[]
  epics                Epic[]
  tasks                Task[]
  platformAccounts     PlatformAccount[]
  invites              Invite[]
  permissionProfiles   PermissionProfile[]
  notifications        Notification[]
}

enum PlatformRole {
  org_admin
  manager
  viewer
}

model PlatformAccount {
  id            String                 @id @default(uuid())
  tenantId      String
  email         String                 @unique
  passwordHash  String
  fullName      String
  role          PlatformRole           @default(viewer)
  isActive      Boolean                @default(true)
  coreUserId    String?                @unique
  preferences   Json?
  lastLoginAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coreUser      User?                  @relation(fields: [coreUserId], references: [id], onDelete: SetNull)
  refreshTokens PlatformRefreshToken[]
  iamAssignments UserPermissionProfile[]

  @@index([tenantId])
}

model PlatformRefreshToken {
  id        String          @id @default(uuid())
  accountId String
  tokenHash String          @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime        @default(now())

  account   PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Invite {
  id        String       @id @default(uuid())
  tenantId  String
  email     String
  role      PlatformRole @default(viewer)
  tokenHash String       @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id         String   @id @default(uuid())
  tenantId   String
  email      String
  fullName   String
  role       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hourlyRate  Float?

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TeamMember[]
  ledTeams    Team[]                  @relation("TeamLead")
  ownedEpics  Epic[]                  @relation("EpicOwner")
  assignedTasks Task[]                @relation("TaskAssignee")
  reportedTasks Task[]                @relation("TaskReporter")
  platformAccount PlatformAccount?

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum ProjectStatus {
  planning
  active
  on_hold
  done
}

enum EpicSource {
  jira
  github
  manual
}

enum EpicStatus {
  backlog
  active
  completed
  cancelled
}

enum TaskSource {
  jira
  github
  manual
}

enum TaskType {
  feature
  bug
  chore
  spike
  tech_debt
}

enum TaskPriority {
  P0
  P1
  P2
  P3
  P4
}

enum TaskStatus {
  backlog
  todo
  in_progress
  review
  done
  cancelled
}

enum IntegrationProvider {
  jira
  github
  opsgenie
  incident_io
}

enum ConnectionStatus {
  active
  disabled
  error
}

enum SecretStrategy {
  vault_ref
  db_encrypted
}

enum SyncMode {
  full
  incremental
}

enum SyncJobStatus {
  queued
  running
  success
  failed
}

enum WebhookEventStatus {
  queued
  processing
  processed
  failed
}

// ── DORA metrics ──────────────────────────────────────────────────────────────

enum DoraLevel {
  elite
  high
  medium
  low
}

enum DeployEventSource {
  github_release
  github_tag
  manual
}

// Immutable record of a production deployment
model DeployEvent {
  id              String            @id @default(uuid())
  tenantId        String
  projectId       String?
  source          DeployEventSource @default(github_release)
  externalId      String?           // GitHub release id / tag sha
  ref             String            // tag or branch name
  commitSha       String?
  environment     String            @default("production")
  deployedAt      DateTime
  isHotfix        Boolean           @default(false)
  isRollback      Boolean           @default(false)
  prIds           String[]          // merged PR ids included in this deploy
  rawPayload      Json?
  createdAt       DateTime          @default(now())

  @@unique([tenantId, source, externalId])
  @@index([tenantId])
  @@index([tenantId, deployedAt])
  @@index([projectId])
}

// Time-series snapshot of a computed DORA / health metric
model HealthMetric {
  id              String    @id @default(uuid())
  tenantId        String
  projectId       String?
  teamId          String?
  metricName      String    // e.g. "deployment_frequency", "lead_time_p50"
  windowDays      Int       @default(30)
  value           Float
  unit            String    // "per_day", "hours", "percent", "count"
  level           DoraLevel?
  computedAt      DateTime  @default(now())
  windowStart     DateTime
  windowEnd       DateTime
  metadata        Json?     // extra context (sample size, percentile, etc.)

  @@index([tenantId, metricName])
  @@index([tenantId, projectId, metricName])
  @@index([computedAt])
}

// ── Incident management ───────────────────────────────────────────────────────

enum IncidentStatus {
  open
  acknowledged
  resolved
  closed
}

// Normalized incident record sourced from OpsGenie or incident.io.
// Owned by the Integrations module. The DORA engine reads this for MTTR/MTTA.
model IncidentEvent {
  id               String              @id @default(uuid())
  tenantId         String
  connectionId     String              // FK → IntegrationConnection
  provider         IntegrationProvider
  externalId       String              // ID in the provider system

  // Lifecycle timestamps — critical for MTTR / MTTA
  openedAt         DateTime            // when the incident was detected/created
  acknowledgedAt   DateTime?           // when first responder acted (MTTA)
  resolvedAt       DateTime?           // when service was restored (MTTR)
  closedAt         DateTime?           // formal close, may differ from resolvedAt

  // Classification (normalized cross-provider)
  priority         String?             // "P1" | "P2" | "P3" | "P4" | "P5"
  severity         String?             // raw severity name from provider
  status           IncidentStatus      @default(open)
  title            String

  // Context
  affectedServices String[]            // service names/IDs from provider, used for project auto-match
  responderIds     String[]            // responder IDs in the provider
  tags             String[]

  // Audit
  rawPayload       Json?
  syncedAt         DateTime            @default(now())

  connection       IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, externalId])
  @@index([tenantId, openedAt])
  @@index([tenantId, priority, resolvedAt])
  @@index([connectionId])
}

model IntegrationConnection {
  id                  String              @id @default(uuid())
  tenantId            String
  provider            IntegrationProvider
  scope               Json?
  typeMapping         Json?               // Record<string, TaskType> — provider raw type → canonical type
  status              ConnectionStatus    @default(active)
  secretStrategy      SecretStrategy      @default(db_encrypted)
  secretLastRotatedAt DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  secrets             IntegrationSecret[]
  syncJobs            IntegrationSyncJob[]
  webhookEvents       IntegrationWebhookEvent[]
  tasks               Task[]
  incidentEvents      IncidentEvent[]

  @@index([tenantId])
  @@index([provider])
}

model Team {
  id               String       @id @default(uuid())
  tenantId         String
  name             String
  description      String?
  leadId           String?
  budgetQuarterly  Float?
  hourlyRate       Float?       // fallback rate when team members have no individual hourlyRate
  tags             String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead             User?        @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  members          TeamMember[]
  projects         Project[]

  @@index([tenantId])
}

model TeamMember {
  id         String   @id @default(uuid())
  teamId      String
  userId      String
  tenantId    String
  createdAt   DateTime @default(now())

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([tenantId])
}

model Project {
  id             String        @id @default(uuid())
  tenantId       String
  key            String
  name           String
  isInitiative   Boolean       @default(true)
  teamId         String?
  status         ProjectStatus @default(planning)
  startDate      DateTime?
  targetEndDate  DateTime?
  syncConfig     Json?
  customFields   Json?
  tags           String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  epics          Epic[]
  tasks          Task[]
  sources        ProjectSource[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model ProjectSource {
  id          String              @id @default(uuid())
  tenantId    String
  projectId   String
  provider    IntegrationProvider
  externalId  String              // JIRA project key (e.g. "AUTH") or GitHub repo full_name (e.g. "org/repo")
  displayName String?
  createdAt   DateTime            @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider, externalId])
  @@index([tenantId])
  @@index([projectId])
}

model Epic {
  id                String      @id @default(uuid())
  tenantId          String
  projectId         String
  source            EpicSource
  sourceId          String?
  name              String
  description       String?
  goal              String?
  status            EpicStatus  @default(backlog)
  startDate         DateTime?
  targetEndDate     DateTime?
  actualEndDate     DateTime?
  ownerId           String?
  totalTasks        Int         @default(0)
  completedTasks    Int         @default(0)
  totalStoryPoints  Int         @default(0)
  actualHours       Float       @default(0)
  healthScore       Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner             User?       @relation("EpicOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks             Task[]

  @@unique([tenantId, source, sourceId])
  @@index([tenantId])
  @@index([projectId])
}

model Task {
  id               String       @id @default(uuid())
  tenantId         String
  source           TaskSource
  sourceId         String?
  projectId        String
  epicId           String?
  title            String
  description      String?
  taskType         TaskType?
  originalType     String?      // Raw type string from the provider (e.g. "Incident", "Security Finding")
  connectionId     String?      // FK → IntegrationConnection (nullable for manual tasks)
  priority         TaskPriority @default(P2)
  status           TaskStatus   @default(backlog)
  assigneeId       String?
  reporterId       String?
  storyPoints      Int?
  hoursEstimated   Float?
  hoursActual      Float?
  startedAt        DateTime?
  completedAt      DateTime?
  dueDate          DateTime?
  cycleTimeHours   Float?
  relatedPrIds     String[]
  tags             String[]
  customFields     Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  epic             Epic?        @relation(fields: [epicId], references: [id], onDelete: SetNull)
  assignee         User?                  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter         User?                  @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  connection       IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  blockerDeps   TaskDependency[] @relation("BlockerDeps")
  blockedDeps   TaskDependency[] @relation("BlockedDeps")

  @@unique([tenantId, source, sourceId])
  @@index([tenantId])
  @@index([projectId])
  @@index([epicId])
  @@index([status])
}

// Blocking relationship between tasks: blocker must finish before blocked can start
model TaskDependency {
  id        String   @id @default(uuid())
  tenantId  String
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   Task     @relation("BlockerDeps", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Task     @relation("BlockedDeps", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([tenantId])
  @@index([blockedId])
}

model SlaTemplate {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  condition       Json     // SlaConditionGroup
  priority        Int      @default(100)
  appliesTo       String[] // TaskType values
  rules           Json     // Record<TaskPriority, { target_minutes: int, warning_at_percent: int }>
  escalationRule  Json?    // { at_risk: {...}, breached: {...} }
  projectIds      String[]
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model IntegrationSecret {
  id            String                @id @default(uuid())
  connectionId  String
  tenantId      String
  strategy      SecretStrategy
  encryptedBlob String
  version       Int                   @default(1)
  createdAt     DateTime              @default(now())

  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, version])
  @@index([tenantId])
}

model IntegrationSyncJob {
  id            String                @id @default(uuid())
  tenantId      String
  connectionId  String
  mode          SyncMode              @default(incremental)
  status        SyncJobStatus         @default(queued)
  createdAt     DateTime              @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  errorSummary  String?
  result        Json?

  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([connectionId])
  @@index([status])
}

model IntegrationWebhookEvent {
  id            String                @id @default(uuid())
  tenantId      String
  provider      IntegrationProvider
  connectionId  String?
  externalId    String
  eventType     String
  payload       Json
  status        WebhookEventStatus    @default(queued)
  attempts      Int                   @default(0)
  lastError     String?
  receivedAt    DateTime              @default(now())
  processedAt   DateTime?

  connection    IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([tenantId, status])
  @@index([provider, status])
}

// ── COGS Module ───────────────────────────────────────────────────────────────

enum CogsCategory {
  engineering    // direct labor — dev, QA, design
  overhead       // indirect: on-call, rework, meetings
  tooling        // JIRA, GitHub, Datadog, Sentry, etc.
  cloud          // AWS/GCP/Azure per project
  administrative // legal, HR, finance allocated to eng
  other
}

enum CogsSource {
  timetracking   // direct from JIRA worklogs or integration
  cycle_time     // derived from SLA cycleTimeHours (startedAt → completedAt)
  story_points   // estimated from SP × velocity
  estimate       // manual estimate (approved)
  manual         // flat entry by manager
}

enum CogsConfidence {
  high    // timetracking or verified data
  medium  // story-points model
  low     // estimate or manual
}

model CogsEntry {
  id            String         @id @default(uuid())
  tenantId      String
  periodDate    DateTime       @db.Date   // day of the work / cost reference
  userId        String?                   // person who generated the cost
  teamId        String?                   // team-level entry (no specific user)
  projectId     String?
  epicId        String?
  taskId        String?

  // cost fields
  hoursWorked   Float          @default(0)
  hourlyRate    Float          @default(0)  // snapshot at time of entry
  overheadRate  Float          @default(1.0) // multiplier, e.g. 1.3 = 30% overhead
  totalCost     Float                        // computed: hoursWorked × hourlyRate × overheadRate
                                             // for non-labor entries: flat cost amount

  // classification
  category      CogsCategory
  subcategory   String?        // free-form: e.g. "ci-cd", "prod-infra", "legal-ip"
  source        CogsSource
  confidence    CogsConfidence @default(medium)

  // revision tracking (for re-derived entries when a task is reopened and re-completed)
  revision      Int            @default(1)
  supersededAt  DateTime?      // set when this entry is replaced by a newer revision
  isDerived     Boolean        @default(false) // true = auto-generated from task; false = manual

  // audit
  notes         String?
  approvedBy    String?        // userId of approver (required for estimate/manual)
  metadata      Json?          // raw data from source (worklog ids, SP breakdown, etc.)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, periodDate])
  @@index([tenantId, projectId])
  @@index([tenantId, epicId])
  @@index([tenantId, taskId])
  @@index([tenantId, userId])
  @@index([tenantId, teamId])
  @@index([tenantId, category])
  @@index([tenantId, taskId, isDerived])
  @@index([supersededAt])
}

model CogsBudget {
  id          String   @id @default(uuid())
  tenantId    String
  projectId   String?  // null = team-level budget
  teamId      String?
  period      String   // e.g. "2026-Q2" or "2026-04"
  budgetAmount Float
  currency    String   @default("USD")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, projectId, teamId, period])
  @@index([tenantId])
  @@index([tenantId, period])
}

// ── Comms Module ─────────────────────────────────────────────────────────────

enum NotificationStatus {
  queued
  processing
  sent
  failed
}

model Notification {
  id          String             @id @default(uuid())
  tenantId    String
  channel     String             // 'email' | 'slack' | 'whatsapp'
  recipient   String
  templateKey String
  payload     Json
  status      NotificationStatus @default(queued)
  attempts    Int                @default(0)
  lastError   String?
  nextRetryAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([status, nextRetryAt])
}

// ── IAM Module ────────────────────────────────────────────────────────────────

model PermissionProfile {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  description    String?
  permissionKeys String[]
  isSystem       Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments UserPermissionProfile[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model UserPermissionProfile {
  id                  String   @id @default(uuid())
  tenantId            String
  accountId           String
  permissionProfileId String
  grantedBy           String
  grantedAt           DateTime @default(now())
  expiresAt           DateTime?
  revokedAt           DateTime?

  account           PlatformAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  permissionProfile PermissionProfile @relation(fields: [permissionProfileId], references: [id], onDelete: Cascade)

  @@unique([accountId, permissionProfileId])
  @@index([tenantId])
  @@index([accountId])
}
