generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         String   @id
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  users      User[]
  connections IntegrationConnection[]
  teams      Team[]
  projects   Project[]
  epics      Epic[]
  tasks      Task[]
}

model User {
  id         String   @id @default(uuid())
  tenantId   String
  email      String
  fullName   String
  role       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TeamMember[]
  ledTeams    Team[]                  @relation("TeamLead")
  ownedEpics  Epic[]                  @relation("EpicOwner")
  assignedTasks Task[]                @relation("TaskAssignee")
  reportedTasks Task[]                @relation("TaskReporter")

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum ProjectStatus {
  planning
  active
  on_hold
  done
}

enum EpicSource {
  jira
  github
  manual
}

enum EpicStatus {
  backlog
  active
  completed
  cancelled
}

enum TaskSource {
  jira
  github
  manual
}

enum TaskType {
  feature
  bug
  chore
  spike
  tech_debt
}

enum TaskPriority {
  P0
  P1
  P2
  P3
  P4
}

enum TaskStatus {
  backlog
  todo
  in_progress
  review
  done
  cancelled
}

enum TaskSlaStatus {
  ok
  at_risk
  breached
  n_a
}

enum SlaInstanceStatus {
  running
  met
  at_risk
  breached
  superseded
}

enum IntegrationProvider {
  jira
  github
}

enum ConnectionStatus {
  active
  disabled
  error
}

enum SecretStrategy {
  vault_ref
  db_encrypted
}

enum SyncMode {
  full
  incremental
}

enum SyncJobStatus {
  queued
  running
  success
  failed
}

enum WebhookEventStatus {
  queued
  processing
  processed
  failed
}

model IntegrationConnection {
  id                  String              @id @default(uuid())
  tenantId            String
  provider            IntegrationProvider
  scope               Json?
  status              ConnectionStatus    @default(active)
  secretStrategy      SecretStrategy      @default(db_encrypted)
  secretLastRotatedAt DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  secrets             IntegrationSecret[]
  syncJobs            IntegrationSyncJob[]
  webhookEvents       IntegrationWebhookEvent[]

  @@index([tenantId])
  @@index([provider])
}

model Team {
  id               String       @id @default(uuid())
  tenantId         String
  name             String
  description      String?
  leadId           String?
  budgetQuarterly  Float?
  tags             String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead             User?        @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  members          TeamMember[]
  projects         Project[]

  @@index([tenantId])
}

model TeamMember {
  id         String   @id @default(uuid())
  teamId      String
  userId      String
  tenantId    String
  createdAt   DateTime @default(now())

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([tenantId])
}

model Project {
  id             String        @id @default(uuid())
  tenantId       String
  key            String
  name           String
  teamId         String?
  status         ProjectStatus @default(planning)
  startDate      DateTime?
  targetEndDate  DateTime?
  syncConfig     Json?
  customFields   Json?
  tags           String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  epics          Epic[]
  tasks          Task[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Epic {
  id                String      @id @default(uuid())
  tenantId          String
  projectId         String
  source            EpicSource
  sourceId          String?
  name              String
  description       String?
  goal              String?
  status            EpicStatus  @default(backlog)
  startDate         DateTime?
  targetEndDate     DateTime?
  actualEndDate     DateTime?
  ownerId           String?
  totalTasks        Int         @default(0)
  completedTasks    Int         @default(0)
  totalStoryPoints  Int         @default(0)
  actualHours       Float       @default(0)
  healthScore       Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner             User?       @relation("EpicOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks             Task[]

  @@index([tenantId])
  @@index([projectId])
}

model Task {
  id               String       @id @default(uuid())
  tenantId         String
  source           TaskSource
  sourceId         String?
  projectId        String
  epicId           String?
  title            String
  description      String?
  taskType         TaskType
  priority         TaskPriority @default(P2)
  status           TaskStatus   @default(backlog)
  assigneeId       String?
  reporterId       String?
  storyPoints      Int?
  hoursEstimated   Float?
  hoursActual      Float?
  startedAt        DateTime?
  completedAt      DateTime?
  dueDate          DateTime?
  slaStatus        TaskSlaStatus @default(n_a)
  cycleTimeHours   Float?
  relatedPrIds     String[]
  tags             String[]
  customFields     Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  epic             Epic?        @relation(fields: [epicId], references: [id], onDelete: SetNull)
  assignee         User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter         User?        @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  slaInstances     SlaInstance[]

  @@index([tenantId])
  @@index([projectId])
  @@index([epicId])
  @@index([status])
}

model SlaTemplate {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  condition       Json     // SlaConditionGroup
  priority        Int      @default(100)
  appliesTo       String[] // TaskType values
  rules           Json     // Record<TaskPriority, { target_minutes: int, warning_at_percent: int }>
  escalationRule  Json?    // { at_risk: {...}, breached: {...} }
  projectIds      String[]
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  instances       SlaInstance[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model SlaInstance {
  id              String            @id @default(uuid())
  taskId          String
  slaTemplateId   String
  tenantId        String
  targetMinutes   Int
  startedAt       DateTime
  deadlineAt      DateTime
  completedAt     DateTime?
  status          SlaInstanceStatus @default(running)
  actualMinutes   Int?
  breachMinutes   Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  task            Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  template        SlaTemplate       @relation(fields: [slaTemplateId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([taskId])
  @@index([status])
  @@index([deadlineAt])
}

model IntegrationSecret {
  id            String                @id @default(uuid())
  connectionId  String
  tenantId      String
  strategy      SecretStrategy
  encryptedBlob String
  version       Int                   @default(1)
  createdAt     DateTime              @default(now())

  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, version])
  @@index([tenantId])
}

model IntegrationSyncJob {
  id            String                @id @default(uuid())
  tenantId      String
  connectionId  String
  mode          SyncMode              @default(incremental)
  status        SyncJobStatus         @default(queued)
  createdAt     DateTime              @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  errorSummary  String?
  result        Json?

  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([connectionId])
  @@index([status])
}

model IntegrationWebhookEvent {
  id            String                @id @default(uuid())
  tenantId      String
  provider      IntegrationProvider
  connectionId  String?
  externalId    String
  eventType     String
  payload       Json
  status        WebhookEventStatus    @default(queued)
  attempts      Int                   @default(0)
  lastError     String?
  receivedAt    DateTime              @default(now())
  processedAt   DateTime?

  connection    IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([tenantId, status])
  @@index([provider, status])
}
